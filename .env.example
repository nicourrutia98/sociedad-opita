# ===================================================================
# Sociedad Opita — Variables de entorno (plantilla)
# Copia este archivo a .env y completa con tus valores
# ===================================================================

# DeepSeek (requerido)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter (fallback opcional)
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AWS (solo si deployas a AWS Lambda)
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# DynamoDB
DYNAMODB_TABLE_USAGE=sociedad-opita-usage
DYNAMODB_TABLE_APIKEYS=sociedad-opita-apikeys
DYNAMODB_TABLE_CITIES=sociedad-opita-cities

# S3 (para outputs largos)
S3_BUCKET_OUTPUTS=sociedad-opita-outputs

# API Gateway / Lambda
API_STAGE=prod
LAMBDA_FUNCTION_NAME=sociedad-opita-simulate
LAMBDA_MEMORY_MB=512
LAMBDA_TIMEOUT_SEC=30

# Logging
LOG_LEVEL=INFO

# Cost caps
MAX_COST_PER_DAY_USD=5.0
ALERT_EMAIL=tu@email.com

# SNS (para alertas de costo)
SNS_TOPIC_COST_ALERT=arn:aws:sns:us-east-1:123456789012:cost-alerts
